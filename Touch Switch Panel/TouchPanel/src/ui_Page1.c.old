void ui_Page1_screen_destroy(void)
{
    if(ui_Page1) lv_obj_del(ui_Page1);

    // NULL screen variables
    ui_Page1 = NULL;
    ui_Button1 = NULL;
    ui_Button1Label = NULL;
    ui_Button1Indicator = NULL;
    ui_Button2 = NULL;
    ui_Button2Label = NULL;
    ui_Button2Indicator = NULL;
    ui_Button3 = NULL;
    ui_Button3Label = NULL;
    ui_Button3Indicator = NULL;
    ui_Button4 = NULL;
    ui_Button4Label = NULL;
    ui_Button4Indicator = NULL;
    ui_Button5 = NULL;
    ui_Button5Label = NULL;
    ui_Button5Indicator = NULL;
    ui_Button6 = NULL;
    ui_Button6Label = NULL;
    ui_Button6Indicator = NULL;
    ui_Page2Button = NULL;
    ui_Page2ButtonLabel = NULL;
    ui_OutTempGauge = NULL;
    ui_OutTempLabel = NULL;
    ui_OutTempDisplay = NULL;
    ui_AirPressureGauge = NULL;
    ui_AirPressureLabel = NULL;
    ui_AirPressureDisplay = NULL;
    ui_AirPressureLabel1 = NULL;

}
